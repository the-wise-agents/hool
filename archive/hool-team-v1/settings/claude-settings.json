{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/block-pl-src-write.sh",
            "timeout": 5
          }
        ],
        "description": "Block Product Lead from editing src/ or tests/ directly"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/suggest-compact.sh",
            "timeout": 3
          }
        ],
        "description": "Suggest strategic /compact at logical intervals"
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/teammate-idle.sh",
            "timeout": 10
          }
        ],
        "description": "Verify teammate wrote completion report and updated memory before going idle"
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/task-completed.sh",
            "timeout": 10
          }
        ],
        "description": "Verify task output matches expectations before marking complete"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/inject-pl-context.sh",
            "timeout": 5
          }
        ],
        "description": "Inject phase-aware PL context on every user prompt"
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/pre-compact.sh",
            "timeout": 10
          }
        ],
        "description": "Save HOOL state snapshot before context compaction"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/agent-checklist.sh",
            "timeout": 5
          }
        ],
        "description": "Operational checklist reminder after each response"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".hool/hooks/agent-checklist.sh",
            "timeout": 5
          }
        ],
        "description": "Operational checklist reminder after subagent completes"
      }
    ]
  }
}
