{
  "name": "hool-cli",
  "version": "0.9.1",
  "description": "Agent-Driven SDLC \u2014 scaffold and configure HOOL for any project",
  "bin": {
    "hool": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts",
